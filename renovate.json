{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:earlyMondays",
    ":semanticCommits",
    ":dependencyDashboard",
    ":separateMajorReleases"
  ],
  "labels": ["renovate"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "rangeStrategy": "bump",
  "pinDigests": true,
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the shellcheck image pinned as SHELLCHECK_IMAGE in .gitlab-ci.yml",
      "managerFilePatterns": ["/(^|/)\\.gitlab-ci\\.yml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+SHELLCHECK_IMAGE: \"[^\"]+:(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "docker base images"
    },
    {
      "matchManagers": ["gitlabci", "gitlabci-include"],
      "groupName": "gitlab-ci"
    }
  ]
}
